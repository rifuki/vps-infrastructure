# ── Backend (rifuki-backend) ────────────────────
PORT=9393
RUST_ENV=production
RUST_LOG=info
CORS_ALLOWED_ORIGINS=https://rifuki.dev,https://backend.rifuki.dev
MAX_SESSIONS=20

# ── Agent (miku-agent) ──────────────────────────
# Note: PORT for agent is set in docker-compose.yml (3939)

# ── LLM Provider ────────────────────────────────
LLM_PROVIDER=
MODEL=

# Kimi
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding

# Claude
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# Minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
